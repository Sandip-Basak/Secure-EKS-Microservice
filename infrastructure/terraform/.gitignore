
# Terraform local state
.terraform/
*.tfstate
*.tfstate.backup
.terraform.tfstate.d/

# Crash log
crash.log

# Exclude CLI configuration files
override.tf
override.tf.json
*_override.tf

# Sensitive variables file
terraform.tfvars
*.tfvars.json

# Terraform plan output
*.tfplan

# Dependency directories
.vendor/

# Lock file (generated by Terraform >= 0.14)
.terraform.lock.hcl

# Local env files
.env

# IDE/editor directories
.idea/
.vscode/
*.swp
*~

# MacOS files
.DS_Store

# Logs and archives
*.log
*.zip

# Kubernetes config (optional)
# kubeconfig
# .kube/
